<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	id="WebApp_ID" version="4.0">
	<display-name>ProjectB</display-name>
	<welcome-file-list>
		<welcome-file>login.jsp</welcome-file>
		<welcome-file>index.html</welcome-file>
		<welcome-file>index.jsp</welcome-file>
		<welcome-file>index.htm</welcome-file>
		<welcome-file>default.html</welcome-file>
		<welcome-file>default.jsp</welcome-file>
		<welcome-file>default.htm</welcome-file>
	</welcome-file-list>

	<filter-mapping>
		<filter-name>LoginFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

	<filter-mapping>
		<filter-name>AdminFilter</filter-name>
		<url-pattern>/addAdmin.jsp</url-pattern>
		<url-pattern>/addRoom.jsp</url-pattern>
		<url-pattern>/adminMenu.jsp</url-pattern>
		<url-pattern>/reservationList.jsp</url-pattern>
	</filter-mapping>

	<filter-mapping>
		<filter-name>ReservationFilter</filter-name>
		<url-pattern>/cancelConfrm.jsp</url-pattern>
		<url-pattern>/canceled.jsp</url-pattern>
		<url-pattern>/cancelError.jsp</url-pattern>
		<url-pattern>/reserveConfirm.jsp</url-pattern>
		<url-pattern>/reserved.jsp</url-pattern>
		<url-pattern>/reserveError.jsp</url-pattern>
	</filter-mapping>
</web-app>
